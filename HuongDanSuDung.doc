<style>
  body { font-family: Arial, sans-serif; font-size: 12pt; margin: 2cm; color: #222; }
  h1 { font-size: 18pt; color: #1a3a5c; border-bottom: 2px solid #1a3a5c; padding-bottom: 6px; }
  h2 { font-size: 14pt; color: #1a3a5c; margin-top: 20px; }
  h3 { font-size: 12pt; color: #2c5f8a; margin-top: 14px; }
  table { border-collapse: collapse; width: 100%; margin: 10px 0; }
  th { background: #1a3a5c; color: white; padding: 6px 10px; text-align: left; }
  td { border: 1px solid #ccc; padding: 5px 10px; }
