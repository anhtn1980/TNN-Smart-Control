  .note { background: #fff8e1; border-left: 4px solid #f0a500; padding: 8px 12px; margin: 10px 0; }
  .tip  { background: #e8f5e9; border-left: 4px solid #4caf50; padding: 8px 12px; margin: 10px 0; }
  .warn { background: #fdecea; border-left: 4px solid #e53935; padding: 8px 12px; margin: 10px 0; }
